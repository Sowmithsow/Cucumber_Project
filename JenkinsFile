pipeline {
    agent any

    tools {
        maven 'Maven3'
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'master',
                    url: 'https://github.com/Sowmithsow/Cucumber_Project.git'
            }
        }

        stage('Build (Skip Tests)') {
            steps {
                bat 'mvn clean install -DskipTests'
            }
        }

        stage('Docker Build') {
            steps {
                // 🔥 Important: no-cache to avoid old broken images
                bat 'docker build --no-cache -t cucumber-framework .'
            }
        }

        stage('Docker Run (Execute Tests)') {
            steps {
                // 🔥 This is where Selenium tests run inside Docker
                bat 'docker run --rm cucumber-framework'
            }
        }
    }

    post {
        success {
            echo '✅ Build Successful - All tests passed'
        }

        failure {
            echo '❌ Build Failed - Check logs for errors'
        }

        always {
            echo 'Pipeline execution completed'
        }
    }
}
